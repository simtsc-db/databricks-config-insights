{
  "datasets": [
    {
      "name": "settings_rows_ds",
      "displayName": "Settings (row level)",
      "query": "SELECT scope, category, setting_name, workspace_id, workspace_name FROM settings_latest"
    },
    {
      "name": "collection_history_ds",
      "displayName": "Collection History",
      "query": "SELECT collected_at, COUNT(*) AS settings_count, COUNT(DISTINCT workspace_id) AS workspaces FROM settings_history GROUP BY collected_at ORDER BY collected_at DESC LIMIT 10"
    },
    {
      "name": "preview_heatmap_ds",
      "displayName": "Preview Features",
      "query": "SELECT feature, description, preview_phase, workspace_name, status FROM preview_heatmap ORDER BY feature, workspace_name"
    },
    {
      "name": "config_drift_ds",
      "displayName": "Configuration Drift",
      "query": "WITH runs AS (SELECT collected_at, DENSE_RANK() OVER (ORDER BY collected_at) AS seq FROM (SELECT DISTINCT collected_at FROM settings_history)), keys AS (SELECT DISTINCT setting_name, COALESCE(workspace_id,0) AS ws FROM settings_history), grid AS (SELECT k.setting_name, k.ws, r.collected_at, r.seq FROM keys k CROSS JOIN runs r), obs AS (SELECT setting_name, COALESCE(workspace_id,0) AS ws, collected_at, MAX(setting_value) AS setting_value, MAX(workspace_name) AS workspace_name, MAX(category) AS category FROM settings_history GROUP BY setting_name, COALESCE(workspace_id,0), collected_at), matrix AS (SELECT g.setting_name, g.ws, g.collected_at, g.seq, o.setting_value, o.workspace_name, o.category FROM grid g LEFT JOIN obs o ON g.setting_name=o.setting_name AND g.ws=o.ws AND g.collected_at=o.collected_at), lagged AS (SELECT setting_name, ws, collected_at, seq, setting_value, workspace_name, category, LAG(setting_value) OVER (PARTITION BY setting_name, ws ORDER BY seq) AS prev_value, LAG(workspace_name) OVER (PARTITION BY setting_name, ws ORDER BY seq) AS prev_ws_name, LAG(category) OVER (PARTITION BY setting_name, ws ORDER BY seq) AS prev_category FROM matrix), cur_cat AS (SELECT setting_name, category FROM (SELECT setting_name, category, ROW_NUMBER() OVER (PARTITION BY setting_name ORDER BY classified_at DESC) AS rn FROM setting_category_map) WHERE rn = 1) SELECT DATE(l.collected_at) AS change_date, l.setting_name, COALESCE(l.workspace_name, l.prev_ws_name) AS workspace_name, COALESCE(cc.category, l.category, l.prev_category) AS category, CASE WHEN l.prev_value IS NULL AND l.setting_value IS NOT NULL THEN 'added' WHEN l.prev_value IS NOT NULL AND l.setting_value IS NULL THEN 'removed' ELSE 'value_changed' END AS change_type, l.prev_value AS previous_value, l.setting_value AS new_value, l.collected_at AS detected_at FROM lagged l LEFT JOIN cur_cat cc ON cc.setting_name = l.setting_name WHERE l.seq > 1 AND ((l.prev_value IS NULL AND l.setting_value IS NOT NULL) OR (l.prev_value IS NOT NULL AND l.setting_value IS NULL) OR (l.prev_value IS NOT NULL AND l.setting_value IS NOT NULL AND l.setting_value <> l.prev_value)) ORDER BY l.collected_at DESC"
    },
    {
      "name": "inconsistencies_ds",
      "displayName": "Inconsistent Settings",
      "query": "SELECT setting_name, category, distinct_values, workspace_count, sample_value, consistency_status FROM workspace_comparison ORDER BY consistency_status, distinct_values DESC"
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Overview & Previews",
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {"lines": ["## Configuration Insights"]}
          },
          "position": {"x": 0, "y": 0, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "workspace-filter",
            "queries": [
              {
                "name": "ws_settings",
                "query": {
                  "datasetName": "settings_rows_ds",
                  "fields": [
                    {"name": "workspace_name", "expression": "`workspace_name`"},
                    {"name": "workspace_name_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                  ],
                  "disaggregated": false
                }
              },
              {
                "name": "ws_heatmap",
                "query": {
                  "datasetName": "preview_heatmap_ds",
                  "fields": [
                    {"name": "workspace_name", "expression": "`workspace_name`"},
                    {"name": "workspace_name_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "filter-single-select",
              "encodings": {
                "fields": [
                  {"fieldName": "workspace_name", "displayName": "Workspace", "queryName": "ws_settings"},
                  {"fieldName": "workspace_name", "displayName": "Workspace", "queryName": "ws_heatmap"}
                ]
              },
              "frame": {"showTitle": true, "title": "Workspace"}
            }
          },
          "position": {"x": 0, "y": 1, "width": 4, "height": 1}
        },
        {
          "widget": {
            "name": "total-settings",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "settings_rows_ds",
                "fields": [{"name": "total_settings", "expression": "COUNT(DISTINCT `setting_name`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "total_settings", "displayName": "Settings Discovered"}
              },
              "frame": {"showTitle": true, "title": "Settings Discovered"}
            }
          },
          "position": {"x": 0, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "workspace-count",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "settings_rows_ds",
                "fields": [{"name": "workspace_count", "expression": "COUNT(DISTINCT CASE WHEN `scope` = 'workspace' THEN `workspace_id` END)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "workspace_count", "displayName": "Workspaces Scanned"}
              },
              "frame": {"showTitle": true, "title": "Workspaces Scanned"}
            }
          },
          "position": {"x": 4, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "preview-count",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "preview_heatmap_ds",
                "fields": [{"name": "preview_count", "expression": "COUNT(DISTINCT `feature`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "preview_count", "displayName": "Preview Features"}
              },
              "frame": {"showTitle": true, "title": "Preview Features"}
            }
          },
          "position": {"x": 8, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "category-chart",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "settings_rows_ds",
                "fields": [
                  {"name": "category", "expression": "`category`"},
                  {"name": "setting_count", "expression": "COUNT(DISTINCT `setting_name`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "category", "scale": {"type": "categorical"}, "displayName": "Category"},
                "y": {"fieldName": "setting_count", "scale": {"type": "quantitative"}, "displayName": "Settings Count"}
              },
              "frame": {"showTitle": true, "title": "Settings by Category"}
            }
          },
          "position": {"x": 0, "y": 5, "width": 6, "height": 5}
        },
        {
          "widget": {
            "name": "scope-chart",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "settings_rows_ds",
                "fields": [
                  {"name": "scope", "expression": "`scope`"},
                  {"name": "setting_count", "expression": "COUNT(`setting_name`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "pie",
              "encodings": {
                "angle": {"fieldName": "setting_count", "scale": {"type": "quantitative"}, "displayName": "Count"},
                "color": {"fieldName": "scope", "scale": {"type": "categorical"}, "displayName": "Scope"}
              },
              "frame": {"showTitle": true, "title": "Settings by Scope"}
            }
          },
          "position": {"x": 6, "y": 5, "width": 6, "height": 5}
        },
        {
          "widget": {
            "name": "collection-history",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "collection_history_ds",
                "fields": [
                  {"name": "collected_at", "expression": "`collected_at`"},
                  {"name": "settings_count", "expression": "`settings_count`"},
                  {"name": "workspaces", "expression": "`workspaces`"}
                ],
                "disaggregated": true
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {"fieldName": "collected_at", "displayName": "Collected At"},
                  {"fieldName": "settings_count", "displayName": "Settings"},
                  {"fieldName": "workspaces", "displayName": "Workspaces"}
                ]
              },
              "frame": {"showTitle": true, "title": "Collection History"}
            }
          },
          "position": {"x": 0, "y": 10, "width": 12, "height": 5}
        },
        {
          "widget": {
            "name": "preview-section-title",
            "multilineTextboxSpec": {"lines": ["## Preview Features"]}
          },
          "position": {"x": 0, "y": 15, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "preview-description",
            "multilineTextboxSpec": {"lines": ["Preview features and their status (ENABLED / DISABLED) per workspace. Use the Workspace filter above, or click a bar (by status or phase) to cross-filter the other preview widgets."]}
          },
          "position": {"x": 0, "y": 16, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "preview-status-bar",
            "queries": [{
              "name": "main_query",
