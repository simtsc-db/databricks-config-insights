{
  "datasets": [
    {
      "name": "current_ds",
      "displayName": "Current settings",
      "query": "SELECT scope, category, setting_name, setting_value, workspace_id, workspace_name, is_preview, status, preview_phase FROM settings_latest"
    },
    {
      "name": "preview_ds",
      "displayName": "Preview features",
      "query": "SELECT setting_name, description, preview_phase, workspace_name, workspace_id, setting_value, status, category FROM settings_latest WHERE is_preview"
    },
    {
      "name": "drift_ds",
      "displayName": "Configuration drift",
      "query": "SELECT change_date, setting_name, workspace_name, category, change_type, previous_value, new_value, detected_at FROM settings_drift ORDER BY detected_at DESC"
    },
    {
      "name": "consistency_ds",
      "displayName": "Cross-workspace consistency",
      "query": "SELECT setting_name, category, distinct_values, workspace_count, sample_value, consistency_status FROM workspace_comparison ORDER BY consistency_status, distinct_values DESC"
    },
    {
      "name": "history_ds",
      "displayName": "Collection history",
      "query": "SELECT collected_at, COUNT(*) AS settings_count, COUNT(DISTINCT workspace_id) AS workspaces FROM settings_history GROUP BY collected_at ORDER BY collected_at DESC LIMIT 10"
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Overview & Previews",
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {"lines": ["## Configuration Insights"]}
          },
          "position": {"x": 0, "y": 0, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "overview-workspace-filter",
            "queries": [
              {
                "name": "ws_current",
                "query": {
                  "datasetName": "current_ds",
                  "fields": [
                    {"name": "workspace_name", "expression": "`workspace_name`"},
                    {"name": "workspace_name_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                  ],
                  "disaggregated": false
                }
              },
              {
                "name": "ws_preview",
                "query": {
                  "datasetName": "preview_ds",
                  "fields": [
                    {"name": "workspace_name", "expression": "`workspace_name`"},
                    {"name": "workspace_name_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "filter-single-select",
              "encodings": {
                "fields": [
                  {"fieldName": "workspace_name", "displayName": "Workspace", "queryName": "ws_current"},
                  {"fieldName": "workspace_name", "displayName": "Workspace", "queryName": "ws_preview"}
                ]
              },
              "frame": {"showTitle": true, "title": "Workspace"}
            }
          },
          "position": {"x": 0, "y": 1, "width": 3, "height": 1}
        },
        {
          "widget": {
            "name": "overview-category-filter",
            "queries": [
              {
                "name": "cat_current",
                "query": {
                  "datasetName": "current_ds",
                  "fields": [
                    {"name": "category", "expression": "`category`"},
                    {"name": "category_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                  ],
                  "disaggregated": false
                }
              },
              {
                "name": "cat_preview",
                "query": {
                  "datasetName": "preview_ds",
                  "fields": [
                    {"name": "category", "expression": "`category`"},
                    {"name": "category_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "filter-multi-select",
              "encodings": {
                "fields": [
                  {"fieldName": "category", "displayName": "Category", "queryName": "cat_current"},
                  {"fieldName": "category", "displayName": "Category", "queryName": "cat_preview"}
                ]
              },
              "frame": {"showTitle": true, "title": "Category"}
            }
          },
          "position": {"x": 3, "y": 1, "width": 3, "height": 1}
        },
        {
          "widget": {
            "name": "total-settings",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "current_ds",
                "fields": [{"name": "total_settings", "expression": "COUNT(DISTINCT `setting_name`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {"value": {"fieldName": "total_settings", "displayName": "Settings Discovered"}},
              "frame": {"showTitle": true, "title": "Settings Discovered"}
            }
          },
          "position": {"x": 0, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "workspace-count",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "current_ds",
                "fields": [{"name": "workspace_count", "expression": "COUNT(DISTINCT CASE WHEN `scope` = 'workspace' THEN `workspace_id` END)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {"value": {"fieldName": "workspace_count", "displayName": "Workspaces Scanned"}},
              "frame": {"showTitle": true, "title": "Workspaces Scanned"}
            }
          },
          "position": {"x": 4, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "preview-count",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "current_ds",
                "fields": [{"name": "preview_count", "expression": "COUNT(DISTINCT CASE WHEN `is_preview` THEN `setting_name` END)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {"value": {"fieldName": "preview_count", "displayName": "Preview Features"}},
              "frame": {"showTitle": true, "title": "Preview Features"}
            }
          },
          "position": {"x": 8, "y": 2, "width": 4, "height": 3}
        },
        {
          "widget": {
            "name": "category-chart",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "current_ds",
                "fields": [
                  {"name": "category", "expression": "`category`"},
                  {"name": "setting_count", "expression": "COUNT(DISTINCT `setting_name`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "category", "scale": {"type": "categorical"}, "displayName": "Category"},
                "y": {"fieldName": "setting_count", "scale": {"type": "quantitative"}, "displayName": "Settings Count"}
              },
              "frame": {"showTitle": true, "title": "Settings by Category"}
            }
          },
          "position": {"x": 0, "y": 5, "width": 6, "height": 5}
        },
        {
          "widget": {
            "name": "scope-chart",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "current_ds",
                "fields": [
                  {"name": "scope", "expression": "`scope`"},
                  {"name": "setting_count", "expression": "COUNT(`setting_name`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "pie",
              "encodings": {
                "angle": {"fieldName": "setting_count", "scale": {"type": "quantitative"}, "displayName": "Count"},
                "color": {"fieldName": "scope", "scale": {"type": "categorical"}, "displayName": "Scope"}
              },
              "frame": {"showTitle": true, "title": "Settings by Scope"}
            }
          },
          "position": {"x": 6, "y": 5, "width": 6, "height": 5}
        },
        {
          "widget": {
            "name": "collection-history",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "history_ds",
                "fields": [
                  {"name": "collected_at", "expression": "`collected_at`"},
                  {"name": "settings_count", "expression": "`settings_count`"},
                  {"name": "workspaces", "expression": "`workspaces`"}
                ],
                "disaggregated": true
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {"fieldName": "collected_at", "displayName": "Collected At"},
                  {"fieldName": "settings_count", "displayName": "Settings"},
                  {"fieldName": "workspaces", "displayName": "Workspaces"}
                ]
              },
              "frame": {"showTitle": true, "title": "Collection History"}
            }
          },
          "position": {"x": 0, "y": 10, "width": 12, "height": 5}
        },
        {
          "widget": {
            "name": "preview-section-title",
            "multilineTextboxSpec": {"lines": ["## Preview Features"]}
          },
          "position": {"x": 0, "y": 15, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "preview-description",
            "multilineTextboxSpec": {"lines": ["Preview features and their status (ENABLED / DISABLED) per workspace. Use the Workspace / Category filters above, or click a status/phase bar to cross-filter the table below."]}
          },
          "position": {"x": 0, "y": 16, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "preview-status-bar",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "preview_ds",
                "fields": [
                  {"name": "status", "expression": "`status`"},
                  {"name": "count(setting_name)", "expression": "COUNT(`setting_name`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "status", "scale": {"type": "categorical"}, "displayName": "Status"},
                "y": {"fieldName": "count(setting_name)", "scale": {"type": "quantitative"}, "displayName": "Feature Count"}
              },
              "frame": {"showTitle": true, "title": "Preview Features by Status"}
            }
          },
          "position": {"x": 0, "y": 17, "width": 6, "height": 5}
        },
        {
          "widget": {
            "name": "preview-phase-bar",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "preview_ds",
                "fields": [
                  {"name": "preview_phase", "expression": "`preview_phase`"},
                  {"name": "count(setting_name)", "expression": "COUNT(`setting_name`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "preview_phase", "scale": {"type": "categorical"}, "displayName": "Phase"},
                "y": {"fieldName": "count(setting_name)", "scale": {"type": "quantitative"}, "displayName": "Feature Count"}
              },
              "frame": {"showTitle": true, "title": "Preview Features by Phase"}
            }
          },
          "position": {"x": 6, "y": 17, "width": 6, "height": 5}
        },
        {
          "widget": {
            "name": "preview-table",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "preview_ds",
                "fields": [
                  {"name": "setting_name", "expression": "`setting_name`"},
                  {"name": "preview_phase", "expression": "`preview_phase`"},
                  {"name": "workspace_name", "expression": "`workspace_name`"},
                  {"name": "status", "expression": "`status`"},
                  {"name": "description", "expression": "`description`"}
                ],
                "disaggregated": true
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {"fieldName": "setting_name", "displayName": "Feature"},
                  {"fieldName": "preview_phase", "displayName": "Phase"},
                  {"fieldName": "workspace_name", "displayName": "Workspace"},
                  {"fieldName": "status", "displayName": "Status"},
                  {"fieldName": "description", "displayName": "Description"}
                ]
              },
              "frame": {"showTitle": true, "title": "Preview Features by Workspace"}
            }
          },
          "position": {"x": 0, "y": 22, "width": 12, "height": 8}
        }
      ]
    },
    {
      "name": "configuration-drift",
      "displayName": "Configuration Drift",
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1",
      "layout": [
        {
          "widget": {
            "name": "drift-title",
            "multilineTextboxSpec": {"lines": ["## Configuration Drift"]}
          },
          "position": {"x": 0, "y": 0, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "drift-workspace-filter",
            "queries": [{
              "name": "ws_drift",
              "query": {
                "datasetName": "drift_ds",
                "fields": [
                  {"name": "workspace_name", "expression": "`workspace_name`"},
                  {"name": "workspace_name_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "filter-single-select",
              "encodings": {
                "fields": [{"fieldName": "workspace_name", "displayName": "Workspace", "queryName": "ws_drift"}]
              },
              "frame": {"showTitle": true, "title": "Workspace"}
            }
          },
          "position": {"x": 0, "y": 1, "width": 3, "height": 1}
        },
        {
          "widget": {
            "name": "drift-category-filter",
            "queries": [
              {
                "name": "cat_drift",
                "query": {
                  "datasetName": "drift_ds",
                  "fields": [
                    {"name": "category", "expression": "`category`"},
                    {"name": "category_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                  ],
                  "disaggregated": false
                }
              },
              {
                "name": "cat_consistency",
                "query": {
                  "datasetName": "consistency_ds",
                  "fields": [
                    {"name": "category", "expression": "`category`"},
                    {"name": "category_associativity", "expression": "COUNT_IF(`associative_filter_context_pass_through`)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "filter-multi-select",
              "encodings": {
                "fields": [
                  {"fieldName": "category", "displayName": "Category", "queryName": "cat_drift"},
                  {"fieldName": "category", "displayName": "Category", "queryName": "cat_consistency"}
                ]
              },
              "frame": {"showTitle": true, "title": "Category"}
            }
          },
          "position": {"x": 3, "y": 1, "width": 3, "height": 1}
        },
        {
          "widget": {
            "name": "drift-description",
            "multilineTextboxSpec": {"lines": ["Configuration drift between collection runs: value_changed / added / removed (unreadable sentinel values are ignored). Use the filters, or click a bar to cross-filter the table below. The Settings API does not expose who made a change; check the audit log for attribution."]}
          },
          "position": {"x": 0, "y": 2, "width": 12, "height": 1}
        },
        {
          "widget": {
            "name": "drift-per-day-bar",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "drift_ds",
                "fields": [
                  {"name": "change_date", "expression": "`change_date`"},
                  {"name": "count(setting_name)", "expression": "COUNT(`setting_name`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "change_date", "scale": {"type": "temporal"}, "displayName": "Date"},
                "y": {"fieldName": "count(setting_name)", "scale": {"type": "quantitative"}, "displayName": "Changes"}
              },
              "frame": {"showTitle": true, "title": "Configuration Changes per Day"}
            }
          },
          "position": {"x": 0, "y": 3, "width": 12, "height": 5}
        },
        {
          "widget": {
            "name": "drift-detail-table",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "drift_ds",
                "fields": [
                  {"name": "change_date", "expression": "`change_date`"},
                  {"name": "setting_name", "expression": "`setting_name`"},
                  {"name": "change_type", "expression": "`change_type`"},
                  {"name": "workspace_name", "expression": "`workspace_name`"},
                  {"name": "category", "expression": "`category`"},
                  {"name": "previous_value", "expression": "`previous_value`"},
                  {"name": "new_value", "expression": "`new_value`"},
                  {"name": "detected_at", "expression": "`detected_at`"}
                ],
                "disaggregated": true
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {"fieldName": "change_date", "displayName": "Date"},
                  {"fieldName": "setting_name", "displayName": "Setting"},
                  {"fieldName": "change_type", "displayName": "Change"},
                  {"fieldName": "workspace_name", "displayName": "Workspace"},
                  {"fieldName": "category", "displayName": "Category"},
                  {"fieldName": "previous_value", "displayName": "Previous Value"},
                  {"fieldName": "new_value", "displayName": "New Value"},
                  {"fieldName": "detected_at", "displayName": "Detected At"}
                ]
              },
              "frame": {"showTitle": true, "title": "Change Details"}
            }
          },
          "position": {"x": 0, "y": 8, "width": 12, "height": 7}
        },
        {
          "widget": {
            "name": "consistency-table",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "consistency_ds",
                "fields": [
                  {"name": "setting_name", "expression": "`setting_name`"},
                  {"name": "category", "expression": "`category`"},
                  {"name": "distinct_values", "expression": "`distinct_values`"},
                  {"name": "workspace_count", "expression": "`workspace_count`"},
                  {"name": "sample_value", "expression": "`sample_value`"},
                  {"name": "consistency_status", "expression": "`consistency_status`"}
                ],
                "disaggregated": true
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {"fieldName": "setting_name", "displayName": "Setting"},
                  {"fieldName": "category", "displayName": "Category"},
                  {"fieldName": "consistency_status", "displayName": "Status"},
                  {"fieldName": "distinct_values", "displayName": "Distinct Values"},
                  {"fieldName": "workspace_count", "displayName": "Workspaces"},
                  {"fieldName": "sample_value", "displayName": "Sample Value"}
                ]
              },
              "frame": {"showTitle": true, "title": "Cross-Workspace Consistency"}
            }
          },
          "position": {"x": 0, "y": 15, "width": 12, "height": 6}
        }
      ]
    }
  ]
}
