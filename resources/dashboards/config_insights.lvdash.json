                "y": {"fieldName": "count(feature)", "scale": {"type": "quantitative"}, "displayName": "Feature Count"}
              },
              "frame": {"showTitle": true, "title": "Preview Features by Phase"}
            }
          },
          "position": {"x": 6, "y": 17, "width": 6, "height": 5}
        },
        {
